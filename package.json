{
  "name": "mendjahit-erp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode local",
    "dev:tunnel": "vite --mode tunnel",
    "dev:prod": "vite --mode production",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && vite build --mode production",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:secrets": "node tools/audit-secrets.mjs",
    "db:prod:link": "npx supabase link --project-ref $SUPABASE_PROD_REF",
    "db:prod:status": "npx supabase status --linked",
    "db:local:reset": "npx supabase db reset",
    "db:local:push": "npx supabase db push --local",
    "db:tunnel:link": "npx supabase link --project-ref $SUPABASE_TUNNEL_REF",
    "db:tunnel:push": "npx supabase db push --linked",
    "db:tunnel:reset": "npx supabase db reset --linked",
    "db:prod:push": "npx supabase db push --linked",
    "db:prod:reset": "npx supabase db reset --linked",
    "gen-types": "npx supabase gen types typescript --local > src/types/supabase.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.90.20",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "html-to-image": "^1.11.13",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "sh -c 'tsc --noEmit --skipLibCheck -p tsconfig.app.json'"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.6",
    "supabase": "^2.74.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.8"
  }
}
